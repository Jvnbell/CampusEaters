# Backend the mobile app talks to. In dev, point at the Next.js website
# running locally. From a phone on the same Wi-Fi, replace localhost with
# your machine's LAN IP (e.g. http://192.168.1.42:3000). On a simulator
# you can leave it as localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000

# The same Supabase project the website uses. Anon key only — never put the
# service role key in this file (it would ship to every user's device).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
